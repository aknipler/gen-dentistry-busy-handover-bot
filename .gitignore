# Secrets / credentials
# NOTE: only secrets.toml is ignored, not the whole .streamlit/ directory -
# keeps the door open for a future .streamlit/config.toml to be committed
# without silently being blocked.
.streamlit/secrets.toml
.env
.env.*
secrets.toml

# Student identifier files (link identifiers back to real students)
*.csv

# Python
.venv/
venv/
__pycache__/

# Voice bot runtime logs (per-process logs written to logs/voice_bot_<port>.log)
logs/
*.log

# Build / packaging output
build/
.dist/

# Session-specific / scratch docs, not part of the shipped project
LATENCY_OPTIMIZATIONS.md
*moshi.pdf
**/*context.md

.python-version