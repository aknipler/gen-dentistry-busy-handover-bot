# Secrets / credentials
# NOTE: only secrets.toml is ignored, not the whole .streamlit/ directory -
# .streamlit/config.toml (enableStaticServing etc.) must be committed for
# Streamlit Community Cloud to pick it up.
.streamlit/secrets.toml
.env
.env.*
secrets.toml

# Student identifier files (link identifiers back to real students)
*.csv

# Per-session voice client HTML written at runtime by
# utils/streamlit_utils.py:render_voice_client (see .streamlit/config.toml's
# enableStaticServing) - not part of the repo, one file per active bot process.
static/*.html

# Python
.venv/
venv/
__pycache__/

# Voice bot runtime logs (per-process logs written to logs/voice_bot_<port>.log)
logs/
*.log

# Build / packaging output
build/
.dist/

# Session-specific / scratch docs, not part of the shipped project
LATENCY_OPTIMIZATIONS.md
*moshi.pdf
**/*context.md

.python-version